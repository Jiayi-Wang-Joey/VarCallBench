Bootstrap: docker
From: rocker/r-ver:4.3.2

%labels
    Author Jiayi
    Description "R plotting env for Omnibenchmark using bound host Python 3.12"

%environment
    export LC_ALL=C
    export LANG=C
    export PATH=/opt/ob_python/bin:/usr/local/bin:/usr/bin:$PATH
    export PYTHONHOME=/opt/ob_python

%post
    set -e

    apt-get update && apt-get install -y \
        libcurl4-openssl-dev \
        libssl-dev \
        libxml2-dev \
        zlib1g-dev \
        libbz2-dev \
        liblzma-dev \
        libxt6 \
        libpng-dev \
        libjpeg-dev \
        libfreetype6-dev \
        libharfbuzz-dev \
        libfribidi-dev \
        git \
        wget \
        bash \
        && rm -rf /var/lib/apt/lists/*

    R -e "install.packages(c('data.table','ggplot2','ComplexUpset'), repos='https://cloud.r-project.org')"
    R -e "if (!requireNamespace('BiocManager', quietly=TRUE)) install.packages('BiocManager', repos='https://cloud.r-project.org')"
    R -e "BiocManager::install('VariantAnnotation', ask=FALSE, update=FALSE)"

    mkdir -p /opt/ob_python/bin
    mkdir -p /opt/ob_python/lib

    cat > /opt/ob_python/bin/python <<'EOF'
#!/bin/sh
export PYTHONHOME=/opt/ob_python
exec /mnt/snakemake_searchpaths/item_3/python3 "$@"
EOF
    chmod +x /opt/ob_python/bin/python

    ln -sf /opt/ob_python/bin/python /opt/ob_python/bin/python3
    ln -sf /opt/ob_python/bin/python /usr/bin/python
    ln -sf /opt/ob_python/bin/python /usr/bin/python3

    ln -sf /mnt/snakemake_searchpaths/item_4 /opt/ob_python/lib/python3.12

%runscript
    exec Rscript "$@"